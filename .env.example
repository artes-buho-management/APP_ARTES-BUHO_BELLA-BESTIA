# Copia este archivo a .env para valores locales
VITE_APP_NAME=APP_ARTES-BUHO_BELLA-BESTIA
VITE_PUBLIC_URL=https://bella-bestia.artesbuhomanagement.com
# Refresco automatico de datos hoja -> app (minutos)
# Recomendado: 5 o 15
VITE_SHEET_AUTO_SYNC_MINUTES=5

# Seguridad de acceso (runtime en servidor)
PANEL_PASSWORD=REPLACE_WITH_PASSWORD
AUTH_SHARED_SECRET=CAMBIAR_SECRETO_SSO_LARGO
COOKIE_DOMAIN=.artesbuhomanagement.com
COOKIE_SECURE=true
PORT=80

# --- Fuente de datos Google Sheets ---
# Si configuras estas variables, la app lee datos desde la hoja de cálculo.
GOOGLE_SHEET_ID=
GOOGLE_SHEET_MAIN_TAB=Introduccion de datos
GOOGLE_SHEET_REPORT_WEEK_TAB=Situacion_Semanal
GOOGLE_SHEET_REPORT_MONTH_TAB=Situacion_Mensual
GOOGLE_SHEET_REPORT_EVENT_TAB=Situacion_Eventos
GOOGLE_SHEET_CONTROL_TAB=Control_App
GOOGLE_SHEET_EVENTS_TAB=Catalogo_Eventos
GOOGLE_SHEET_MANUAL_TAB=Manual_Uso
DASHBOARD_URL=https://bella-bestia.artesbuhomanagement.com
GOOGLE_SHEETS_READ_ONLY=true
GOOGLE_SHEETS_PUBLIC_FALLBACK=true
GOOGLE_SHEETS_AUTO_BOOTSTRAP=true
GOOGLE_SHEETS_AUTO_REBUILD_REPORTS=true
GOOGLE_SHEETS_AUTO_PRUNE_TABS=true

# Credenciales (elige 1 formato):
# 1) JSON completo en una sola variable
# GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
#
# 2) JSON en Base64 (muy util en Coolify)
# GOOGLE_SERVICE_ACCOUNT_JSON_BASE64=
#
# 3) Email + private key separados
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY=

# Opcional: delegación de dominio (Google Workspace)
# GOOGLE_IMPERSONATE_USER=booking@artesbuhomanagement.com
